# ─── Base de datos ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql://usuario:password@host:5432/railway

# ─── Redis (opcional, solo si usas caché) ────────────────────────────────────
REDIS_URL=redis://host:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=genera-una-cadena-larga-y-aleatoria-aqui
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=otra-cadena-larga-diferente-al-jwt-secret
JWT_REFRESH_EXPIRES_IN=30d

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
FRONTEND_URL=https://app.carolinapos.co

# ─── Super Admin ─────────────────────────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@carolinapos.co
SUPER_ADMIN_PASSWORD=cambia-esta-contrasena

# ─── Factus (Facturación Electrónica DIAN) ───────────────────────────────────
# Sandbox:    https://api-sandbox.factus.com.co
# Producción: https://api.factus.com.co
FACTUS_BASE_URL=https://api-sandbox.factus.com.co
FACTUS_CLIENT_ID=tu-client-id-factus
FACTUS_CLIENT_SECRET=tu-client-secret-factus
FACTUS_USERNAME=tu-usuario-factus
FACTUS_PASSWORD=tu-password-factus

# ─── Email (Zoho Mail / Gmail SMTP) ──────────────────────────────────────────
# Para Gmail: usar "Contraseña de aplicación" (Cuenta → Seguridad → 2FA → App passwords)
EMAIL_USER=noreply@carolinapos.co
EMAIL_PASS=tu-contrasena-de-aplicacion
EMAIL_FROM=CarolinaPOS <noreply@carolinapos.co>
